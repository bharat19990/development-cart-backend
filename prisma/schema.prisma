generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
  ORGANIZATION
}

enum SessionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  WAIVED
}

enum PaymentType {
  SELF
  SPONSORED
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  role             Role     @default(USER)
  profileCompleted Boolean  @default(false) @map("profile_completed")
  organizationId   String?  @map("organization_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization           Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  administeredSessions   Session[]       @relation("SessionAdmin")
  enrollments            Enrollment[]
  scores                 Score[]
  sponsorshipsReceived Sponsorship[]   @relation("SponsoredUser")
  dailyVideoWatches      DailyVideoWatch[]
  dailyQuizAttempts      DailyQuizAttempt[]

  @@index([organizationId])
  @@map("users")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members      User[]
  sessions     Session[]
  sponsorships Sponsorship[]

  @@map("organizations")
}

model Session {
  id             String        @id @default(uuid())
  title          String
  description    String?
  status         SessionStatus @default(DRAFT)
  adminId        String        @map("admin_id")
  organizationId String?       @map("organization_id")
  startsAt       DateTime      @map("starts_at")
  endsAt         DateTime      @map("ends_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  admin            User              @relation("SessionAdmin", fields: [adminId], references: [id], onDelete: Restrict)
  organization     Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  enrollments      Enrollment[]
  videos            Video[]
  quizzes           Quiz[]
  scores            Score[]
  sponsorships      Sponsorship[]
  dailyVideoWatches DailyVideoWatch[]
  dailyQuizAttempts DailyQuizAttempt[]

  @@index([adminId])
  @@index([organizationId])
  @@index([status])
  @@index([endsAt])
  @@map("sessions")
}

model Enrollment {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  sessionId     String        @map("session_id")
  paymentType   PaymentType   @map("payment_type")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  amount        Decimal       @default(100) @db.Decimal(12, 2)
  enrolledAt    DateTime      @default(now()) @map("enrolled_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sponsorship Sponsorship?

  @@unique([userId, sessionId])
  @@index([sessionId])
  @@map("enrollments")
}

model Video {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  title       String
  description String?
  url         String
  durationSec Int?     @map("duration_sec")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  session           Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  dailyVideoWatches DailyVideoWatch[]

  @@index([sessionId])
  @@map("videos")
}

model Quiz {
  id           String   @id @default(uuid())
  sessionId    String   @map("session_id")
  title        String
  description  String?
  passingScore Int      @default(70) @map("passing_score")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  session           Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scores            Score[]
  dailyQuizAttempts DailyQuizAttempt[]

  @@index([sessionId])
  @@map("quizzes")
}

model Score {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  quizId      String   @map("quiz_id")
  sessionId   String   @map("session_id")
  value       Int
  maxValue    Int      @default(100) @map("max_value")
  completedAt DateTime @default(now()) @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz    Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([quizId])
  @@map("scores")
}

model DailyVideoWatch {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  sessionId    String   @map("session_id")
  videoId      String   @map("video_id")
  activityDate DateTime @db.Date @map("activity_date")
  watchedAt    DateTime @default(now()) @map("watched_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  video   Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId, activityDate])
  @@map("daily_video_watches")
}

model DailyQuizAttempt {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  sessionId    String   @map("session_id")
  quizId       String   @map("quiz_id")
  activityDate DateTime @db.Date @map("activity_date")
  value        Int
  maxValue     Int      @default(100) @map("max_value")
  attemptedAt  DateTime @default(now()) @map("attempted_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  quiz    Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId, activityDate])
  @@map("daily_quiz_attempts")
}

model Sponsorship {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  userId         String        @map("user_id")
  sessionId      String        @map("session_id")
  enrollmentId   String        @unique @map("enrollment_id")
  amount         Decimal       @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(PAID) @map("payment_status")
  sponsoredAt    DateTime      @default(now()) @map("sponsored_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("SponsoredUser", fields: [userId], references: [id], onDelete: Cascade)
  session      Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, sessionId])
  @@index([sessionId])
  @@index([userId])
  @@map("sponsorships")
}
