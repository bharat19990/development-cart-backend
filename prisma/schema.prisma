generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SUPERADMIN
  ADMIN
  USER
  ORGANIZATION
}

enum SessionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  WAIVED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  role              Role     @default(USER)
  profileCompleted  Boolean  @default(false) @map("profile_completed")
  organizationId    String?  @map("organization_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  administeredSessions Session[]   @relation("SessionAdmin")
  enrollments        Enrollment[]
  scores             Score[]

  @@index([organizationId])
  @@map("users")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members      User[]
  sessions     Session[]
  sponsorships Sponsorship[]

  @@map("organizations")
}

model Session {
  id             String        @id @default(uuid())
  title          String
  description    String?
  status         SessionStatus @default(DRAFT)
  adminId        String        @map("admin_id")
  organizationId String?       @map("organization_id")
  startsAt       DateTime?     @map("starts_at")
  endsAt         DateTime?     @map("ends_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  admin          User           @relation("SessionAdmin", fields: [adminId], references: [id], onDelete: Restrict)
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  enrollments    Enrollment[]
  videos         Video[]
  quizzes        Quiz[]
  sponsorships   Sponsorship[]

  @@index([adminId])
  @@index([organizationId])
  @@index([status])
  @@map("sessions")
}

model Enrollment {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  sessionId     String        @map("session_id")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  enrolledAt    DateTime      @default(now()) @map("enrolled_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionId])
  @@index([sessionId])
  @@map("enrollments")
}

model Video {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  title       String
  description String?
  url         String
  durationSec Int?     @map("duration_sec")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("videos")
}

model Quiz {
  id           String   @id @default(uuid())
  sessionId    String   @map("session_id")
  title        String
  description  String?
  passingScore Int      @default(70) @map("passing_score")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scores  Score[]

  @@index([sessionId])
  @@map("quizzes")
}

model Score {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  quizId      String   @map("quiz_id")
  value       Int
  maxValue    Int      @default(100) @map("max_value")
  completedAt DateTime @default(now()) @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([quizId])
  @@map("scores")
}

model Sponsorship {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  sessionId      String        @map("session_id")
  amount         Decimal       @db.Decimal(12, 2)
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  sponsoredAt    DateTime      @default(now()) @map("sponsored_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session      Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sessionId])
  @@index([sessionId])
  @@map("sponsorships")
}
